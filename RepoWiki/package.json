{
  "name": "deepwiki-analyzer",
  "version": "1.0.0",
  "description": "DeepWiki 代码仓库分析工具 - 将 Gitee 公开仓库整理为结构化 MD 文档",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "cd client && npm run dev",
    "start": "node server/index.js",
    "start:quick": "node scripts/start.js",
    "build": "cd client && npm run build",
    "install:all": "npm install && cd client && npm install"
  },
  "keywords": [
    "deepwiki",
    "code-analysis",
    "gitee",
    "langchain",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/openai": "^0.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "highlight.js": "^11.9.0",
    "marked": "^12.0.0",
    "puppeteer": "^22.0.0",
    "simple-git": "^3.22.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}